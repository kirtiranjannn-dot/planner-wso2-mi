<api name="planneruat" context="/planneruat"
     xmlns="http://ws.apache.org/ns/synapse">

<!-- ================= Create User (Insert User) ============== -->

    <resource methods="POST" uri-template="/users">

        <inSequence>

            <payloadFactory media-type="json">
                <format>
                {
                  "_postcreateUser":{
                    "username":"$1",
                    "email":"$2",
                    "first_name":"$3",
                    "last_name":"$4",
                    "display_name":"$5",
                    "profile_image":"$6",
                    "tenant_id":"$7",
                    "version":$8,
                    "created_by":$9
                  }
                }
                </format>

                <args>
                    <arg evaluator="json" expression="$.username"/>
                    <arg evaluator="json" expression="$.email"/>
                    <arg evaluator="json" expression="$.first_name"/>
                    <arg evaluator="json" expression="$.last_name"/>
                    <arg evaluator="json" expression="$.display_name"/>
                    <arg evaluator="json" expression="$.profile_image"/>
                    <arg evaluator="json" expression="$.tenant_id"/>
                    <arg evaluator="json" expression="$.version"/>
                    <arg evaluator="json" expression="$.created_by"/>
                </args>
            </payloadFactory>

            <log level="full"/>

            <!-- <dataServiceCall serviceName="UserDataService_DSS">
                <source type="body"/>

                <operations type="single">
                    <operation name="createUser"/>
                </operations>
                
                <target type="body"/>
            </dataServiceCall> -->

            <call>
                <endpoint>
                    <http method="POST"
                        uri-template="http://localhost:8290/services/UserDataService_DSS/createUser"/>
                </endpoint>
            </call>

            <respond/>

        </inSequence>

        <faultSequence>
            <log level="full"/>
            <respond/>
        </faultSequence>

    </resource>



    <!-- =========================== Get Users ========================== -->

    <resource methods="GET" uri-template="/users">

    <inSequence>

        <call>

            <endpoint>

                <http method="GET"
                      uri-template="http://localhost:8290/services/UserDataService_DSS/getAllUsers"/>

            </endpoint>

        </call>

        <property name="messageType"
                  value="application/json"
                  scope="axis2"/>

        <respond/>

    </inSequence>

    <faultSequence>

        <log level="full"/>

        <respond/>

    </faultSequence>

</resource>


