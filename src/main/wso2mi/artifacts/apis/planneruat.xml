<!-- Add XML Data -->
<api name="planneruat" context="/planneruat" xmlns="http://ws.apache.org/ns/synapse">
    <!-- ================= Create User (Insert User) ============== -->
    <resource methods="POST" uri-template="/users">
        <inSequence>
            <!-- ================= JSON Schema Validation ================= -->
            <validate cache-schema="true">
                <schema key="create-user-schema"/>
                <on-fail>
                    <payloadFactory media-type="json">
                        <format>
                            {
                            "success":false,
                            "message":"Invalid Request"
                            }
                        </format>
                        <args/>
                    </payloadFactory>
                    <property name="HTTP_SC" value="400" scope="axis2"/>
                    <respond/>
                </on-fail>
            </validate>
            <!-- ================= Save Original Request ================= -->
            <enrich>
                <source clone="true" type="body"/>
                <target property="originalRequest" type="property"/>
            </enrich>
            <!-- ================= Read Username ================= -->
            <property name="username" expression="json-eval($.username)" scope="default" type="STRING"/>
            <!-- <log level="custom">
            <property name="Username_Log" expression="get-property('username')"/>
        </log>
        <property name="uri.var.fullURL"
          expression="fn:concat(
              'http://localhost:8290/services/UserDataService_DSS/getUserByUsername?username=',get-property('username'))"/> -->
            <payloadFactory media-type="xml">
                <format>
                    <getUserByUsernameOP>
                        <username>$1</username>
                    </getUserByUsernameOP>
                </format>
                <args>
                    <arg evaluator="xml" expression="get-property('username')"/>
                </args>
            </payloadFactory>
            <log level="custom">
                <property expression="$body" name="!!! before hitting getUserByUsername !!!" xmlns:ns="http://org.apache.synapse/xsd"/>
            </log>
            <!-- ================= Check Username ================= -->
            <property name="SOAPAction" scope="transport" type="STRING" value="urn:getUserByUsernameOP"/>
            <call>
                <endpoint key="Get_User_By_Username_EP"/>
            </call>
            <log level="custom">
                <property name="After Get_User_By_Username_EP" value="Get_User_By_Username_EP"/>
                <property name="Get_User_By_Username_DB_SC" expression="get-property('axis2','HTTP_SC')"/>
                <property name="Get_User_By_Username_EP_Res" expression="json-eval($)"/>
            </log>
            <!-- ================= Username Exists ================= -->
            <property name="userDetails_Result" expression="json-eval($.User.UserDetails)" scope="default" type="STRING"/>
            <filter xpath="get-property('userDetails_Result') != '' ">
                <then>
                    <payloadFactory media-type="json">
                        <format>
                            {
                            "success":false,
                            "message":"Username already exists"
                            }
                        </format>
                        <args/>
                    </payloadFactory>
                    <property name="HTTP_SC" value="409" scope="axis2"/>
                    <respond/>
                </then>
                <else>
                    <!-- ================= Restore Request ================= -->
                    <enrich>
                        <source property="originalRequest" type="property"/>
                        <target type="body"/>
                    </enrich>
                    <!-- ================= Read Email ================= -->
                    <property name="email" expression="json-eval($.email)" scope="default" type="STRING"/>
                    <payloadFactory media-type="xml">
                        <format>
                            <getUserByEmailOP>
                                <email>$1</email>
                            </getUserByEmailOP>
                        </format>
                        <args>
                            <arg evaluator="xml" expression="get-property('email')"/>
                        </args>
                    </payloadFactory>
                    <log level="custom">
                        <property expression="$body" name="!!! before hitting getUserByEmailOP !!!" xmlns:ns="http://org.apache.synapse/xsd"/>
                    </log>
                    <!-- ================= Check Email ================= -->
                    <property name="SOAPAction" scope="transport" type="STRING" value="urn:getUserByEmailOP"/>
                    <call>
                        <endpoint key="Get_User_By_Email_EP"/>
                    </call>
                    <log level="custom">
                        <property name="After Get_User_By_Email_EP" value="Get_User_By_Email_EP"/>
                        <property name="Get_User_By_Email_DB_SC" expression="get-property('axis2','HTTP_SC')"/>
                        <property name="Get_User_By_Email_EP_Res" expression="json-eval($)"/>
                    </log>
                    <!-- ================= Email Exists ================= -->
                    <property name="userDetails_Result" expression="json-eval($.User.UserDetails)" scope="default" type="STRING"/>
                    <filter xpath="get-property('userDetails_Result') != '' ">
                        <then>
                            <payloadFactory media-type="json">
                                <format>
                                    {
                                    "success":false,
                                    "message":"Email already exists"
                                    }
                                </format>
                                <args/>
                            </payloadFactory>
                            <property name="HTTP_SC" value="409" scope="axis2"/>
                            <respond/>
                        </then>
                        <else>
                            <enrich>
                                <source property="originalRequest" type="property"/>
                                <target type="body"/>
                            </enrich>
                            <payloadFactory media-type="json">
                                <format>
                                    {
                                    "_postcreateUser":{
                                    "username":"$1",
                                    "email":"$2",
                                    "first_name":"$3",
                                    "last_name":"$4",
                                    "display_name":"$5",
                                    "profile_image":"$6",
                                    "tenant_id":"$7",
                                    "version":$8,
                                    "created_by":$9
                                    }
                                    }
                                </format>
                                <args>
                                    <arg evaluator="json" expression="$.username"/>
                                    <arg evaluator="json" expression="$.email"/>
                                    <arg evaluator="json" expression="$.first_name"/>
                                    <arg evaluator="json" expression="$.last_name"/>
                                    <arg evaluator="json" expression="$.display_name"/>
                                    <arg evaluator="json" expression="$.profile_image"/>
                                    <arg evaluator="json" expression="$.tenant_id"/>
                                    <arg evaluator="json" expression="$.version"/>
                                    <arg evaluator="json" expression="$.created_by"/>
                                </args>
                            </payloadFactory>
                            <log level="full"/>
                            <call>
                                <endpoint>
                                    <http method="POST" uri-template="http://localhost:8290/services/UserDataService_DSS/createUser"/>
                                </endpoint>
                            </call>
                            <filter xpath="${payload.id.user[0].id != ''}">
                                <then>
                                    <payloadFactory media-type="json">
                                        <format>
                                            {
                                            "success":true,
                                            "description":"User Successfully created"
                                            }
                                        </format>
                                    </payloadFactory>
                                </then>
                                <else>
                                    <payloadFactory media-type="json">
                                        <format>
                                            {
                                            "success":false,
                                            "description":"User Creation Failed due to unknown errors"
                                            }
                                        </format>
                                    </payloadFactory>
                                </else>
                            </filter>
                            <respond/>
                        </else>
                    </filter>
                </else>
            </filter>
        </inSequence>
    </resource>
    <!-- =========================== Get Users ========================== -->
    <resource methods="GET" uri-template="/users">
        <inSequence>
            <call>
                <endpoint>
                    <http method="GET" uri-template="http://localhost:8290/services/UserDataService_DSS/getAllUsers"/>
                </endpoint>
            </call>
            <property name="users" expression="json-eval($.Users.User)" scope="default" type="STRING"/>
            <filter xpath="get-property('users') = ''">
                <then>
                    <payloadFactory media-type="json">
                        <format>
                            {
                            "success":false,
                            "message":"No users found"
                            }
                        </format>
                        <args/>
                    </payloadFactory>
                    <property name="HTTP_SC" value="404" scope="axis2"/>
                    <respond/>
                </then>
                <else>
                    <property name="messageType" value="application/json" scope="axis2"/>
                    <respond/>
                </else>
            </filter>
        </inSequence>
        <faultSequence>
            <log level="full"/>
            <respond/>
        </faultSequence>
    </resource>
    <!-- ==================== get user count ======================= -->
    <resource methods="GET" uri-template="/users/count">
        <inSequence>
            <property name="Accept" value="application/json" scope="transport"/>
            <call>
                <endpoint>
                    <http method="GET" uri-template="http://localhost:8290/services/UserDataService_DSS/getUserCount"/>
                </endpoint>
            </call>
            <property name="count" expression="json-eval($.Users.count)" scope="default"/>
            <filter xpath="get-property('count') != ''">
                <then>
                    <payloadFactory media-type="json">
                        <format>
                            {
                            "success":false,
                            "message":"Unable to fetch user count"
                            }
                        </format>
                    </payloadFactory>
                    <property name="HTTP_SC" value="500" scope="axis2"/>
                    <respond/>
                </then>
                <else>
                    <property name="messageType" value="application/json" scope="axis2"/>
                    <property name="ContentType" value="application/json" scope="axis2"/>
                    <respond/>
                </else>
            </filter>
        </inSequence>
        <faultSequence>
            <log level="full"/>
            <respond/>
        </faultSequence>
    </resource>
    <!-- =================  get user by uuid ================= -->
    <resource methods="GET" uri-template="/users/uuid/{uuid}">
        <inSequence>
            <filter source="get-property('uri.var.uuid')" regex="^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$">
                <then>
                    <property name="Accept" value="application/json" scope="transport"/>
                    <call>
                        <endpoint>
                            <http method="GET" uri-template="http://localhost:8290/services/UserDataService_DSS/getUserByUUID?uuid={uri.var.uuid}"/>
                        </endpoint>
                    </call>
                    <property name="user" expression="json-eval($.User.UserDetails)" scope="default"/>
                    <filter xpath="get-property('user') = ''">
                        <then>
                            <payloadFactory media-type="json">
                                <format>
                                    {
                                    "success":false,
                                    "message":"User not found"
                                    }
                                </format>
                                <args/>
                            </payloadFactory>
                            <property name="HTTP_SC" value="404" scope="axis2"/>
                            <respond/>
                        </then>
                        <else>
                            <property name="messageType" value="application/json" scope="axis2"/>
                            <property name="ContentType" value="application/json" scope="axis2"/>
                            <respond/>
                        </else>
                    </filter>
                </then>
                <else>
                    <payloadFactory media-type="json">
                        <format>
                            {
                            "success":false,
                            "message":"Invalid User UUID"
                            }
                        </format>
                    </payloadFactory>
                    <property name="HTTP_SC" value="400" scope="axis2"/>
                    <respond/>
                </else>
            </filter>
        </inSequence>
        <faultSequence>
            <log level="full"/>
            <respond/>
        </faultSequence>
    </resource>
    <!-- ================ get user by username =============== -->
    <resource methods="GET" uri-template="/users/username/{username}">
        <inSequence>
            <filter source="get-property('uri.var.username')" regex="^[A-Za-z][A-Za-z0-9_]{2,29}$">
                <then>
                    <property name="Accept" value="application/json" scope="transport"/>
                    <call>
                        <endpoint>
                            <http method="GET" uri-template="http://localhost:8290/services/UserDataService_DSS/getUserByUsername?username={uri.var.username}"/>
                        </endpoint>
                    </call>
                    <property name="user" expression="json-eval($.User.UserDetails)"/>
                    <filter xpath="get-property('user') = ''">
                        <then>
                            <payloadFactory media-type="json">
                                <format>
                                    {
                                    "success":false,
                                    "message":"Username not found"
                                    }
                                </format>
                            </payloadFactory>
                            <property name="HTTP_SC" value="404" scope="axis2"/>
                            <respond/>
                        </then>
                        <else>
                            <log level="full"/>
                            <property name="messageType" value="application/json" scope="axis2"/>
                            <property name="ContentType" value="application/json" scope="axis2"/>
                            <respond/>
                        </else>
                    </filter>
                </then>
                <else>
                    <payloadFactory media-type="json">
                        <format>
                            {
                            "success":false,
                            "message":"Invalid Username"
                            }
                        </format>
                    </payloadFactory>
                    <property name="HTTP_SC" value="400" scope="axis2"/>
                    <respond/>
                </else>
            </filter>
        </inSequence>
        <faultSequence>
            <log level="full"/>
            <respond/>
        </faultSequence>
    </resource>
    <!-- ================= get user by email ================== -->
    <resource methods="GET" uri-template="/users/email/{email}">
