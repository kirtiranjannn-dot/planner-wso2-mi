<!-- ====================== put update user =================== -->

<resource methods="PUT" uri-template="/users/{id}">

    <inSequence>

        <payloadFactory media-type="json">

            <format>
            {
                "_putupdateUser":{
                    "id":$1,
                    "username":"$2",
                    "email":"$3",
                    "first_name":"$4",
                    "last_name":"$5",
                    "display_name":"$6",
                    "profile_image":"$7",
                    "tenant_id":"$8",
                    "version":$9,
                    "updated_by":$10
                }
            }
            </format>

            <args>
                <arg expression="get-property('uri.var.id')"/>
                <arg evaluator="json" expression="$.username"/>
                <arg evaluator="json" expression="$.email"/>
                <arg evaluator="json" expression="$.first_name"/>
                <arg evaluator="json" expression="$.last_name"/>
                <arg evaluator="json" expression="$.display_name"/>
                <arg evaluator="json" expression="$.profile_image"/>
                <arg evaluator="json" expression="$.tenant_id"/>
                <arg evaluator="json" expression="$.version"/>
                <arg evaluator="json" expression="$.updated_by"/>
            </args>

        </payloadFactory>

        <property name="Accept"
                  value="application/json"
                  scope="transport"/>

        <call>

            <endpoint>

                <http method="PUT"
                      uri-template="http://localhost:8290/services/UserDataService_DSS/updateUser"/>

            </endpoint>

        </call>

        <property name="messageType"
                  value="application/json"
                  scope="axis2"/>

        <property name="ContentType"
                  value="application/json"
                  scope="axis2"/>

        <respond/>

    </inSequence>

    <faultSequence>

        <log level="full"/>

        <respond/>

    </faultSequence>

</resource>


<!--  ========================== soft delete user ======================= -->

<resource methods="DELETE" uri-template="/users/{id}">

    <inSequence>

        <payloadFactory media-type="json">
            <format>
            {
                "_deletedeleteUser":{
                    "id":$1,
                    "deleted_by":$2
                }
            }
            </format>

            <args>
                <arg expression="get-property('uri.var.id')"/>
                <arg evaluator="json" expression="$.deleted_by"/>
            </args>

        </payloadFactory>

        <property name="Accept"
                  value="application/json"
                  scope="transport"/>

        <call>

            <endpoint>

                <http method="DELETE"
                      uri-template="http://localhost:8290/services/UserDataService_DSS/deleteUser"/>

            </endpoint>

        </call>

        <payloadFactory media-type="json">
            <format>
            {
                "message":"User deleted successfully"
            }
            </format>
            <args/>
        </payloadFactory>

        <property name="messageType"
                  value="application/json"
                  scope="axis2"/>

        <property name="ContentType"
                  value="application/json"
                  scope="axis2"/>

        <respond/>

    </inSequence>

    <faultSequence>

        <log level="full"/>

        <respond/>

    </faultSequence>

</resource>

