        </inSequence>
        <faultSequence>
            <log level="full"/>
            <respond/>
        </faultSequence>
    </resource>
    <!-- ==================== get users by id ======================= -->
    <resource methods="GET" uri-template="/users/{id}">
        <inSequence>
            <filter source="get-property('uri.var.id')" regex="^[0-9]+$">
                <then>
                    <call>
                        <endpoint>
                            <http method="GET" uri-template="http://localhost:8290/services/UserDataService_DSS/getUserById?id={uri.var.id}"/>
                        </endpoint>
                    </call>
                    <property name="user" expression="json-eval($.User.UserDetails)" scope="default"/>
                    <filter xpath="get-property('user') = ''">
                        <then>
                            <payloadFactory media-type="json">
                                <format>
                                    {
                                    "success":false,
                                    "message":"User not found"
                                    }
                                </format>
                            </payloadFactory>
                            <property name="HTTP_SC" value="404" scope="axis2"/>
                            <respond/>
                        </then>
                        <else>
                            <property name="messageType" value="application/json" scope="axis2"/>
                            <property name="ContentType" value="application/json" scope="axis2"/>
                            <respond/>
                        </else>
                    </filter>
                </then>
                <else>
                    <payloadFactory media-type="json">
                        <format>
                            {
                            "success":false,
                            "message":"Invalid User ID"
                            }
                        </format>
                    </payloadFactory>
                    <property name="HTTP_SC" value="400" scope="axis2"/>
                    <respond/>
                </else>
            </filter>
        </inSequence>
        <faultSequence>
            <log level="full"/>
            <respond/>
        </faultSequence>
    </resource>
    <!-- ====================== put update user =================== -->
    <resource methods="PUT" uri-template="/users/{id}">
        <inSequence>
            <validate cache-schema="true">
                <schema key="update-user-schema"/>
                <on-fail>
                    <payloadFactory media-type="json">
                        <format>
                            {
                            "success":false,
                            "message":"Invalid Request"
                            }
                        </format>
                        <args/>
                    </payloadFactory>
                    <property name="HTTP_SC" value="400" scope="axis2"/>
                    <respond/>
                </on-fail>
            </validate>
            <filter source="get-property('uri.var.id')" regex="^[0-9]+$">
                <then>
                    <enrich>
                        <source clone="true" type="body"/>
                        <target property="originalRequest" type="property"/>
                    </enrich>
                    <log level="custom">
                        <property name="URI_VAR_ID" expression="get-property('uri.var.id')"/>
                        <property name="REST_URL_POSTFIX" expression="get-property('REST_URL_POSTFIX')"/>
                    </log>
                    <payloadFactory media-type="xml">
                        <format>
                            <getUserByIdOP>
                                <id>$1</id>
                            </getUserByIdOP>
                        </format>
                        <args>
                            <arg evaluator="xml" expression="get-property('uri.var.id')"/>
                        </args>
                    </payloadFactory>
                    <property name="SOAPAction" scope="transport" type="STRING" value="urn:getUserByIdOP"/>
                    <call>
                        <endpoint key="Get_User_By_Id_Ep"/>
                    </call>
                    <!-- <call>
                        <endpoint>
                            <http method="GET"
                             uri-template="http://localhost:8290/services/UserDataService_DSS/getUserById?id={uri.var.id}"/>
                        </endpoint>
                    </call> -->
                    <log level="full"/>
                    <property name="messageType" value="application/json" scope="axis2"/>
                    <property name="ContentType" value="application/json" scope="axis2"/>
                    <property name="userDetails_Result" expression="json-eval($.User.UserDetails)" scope="default"/>
                    <filter xpath="get-property('userDetails_Result') = ''">
                        <then>
                            <payloadFactory media-type="json">
                                <format>
                                    {
                                    "success":false,
                                    "message":"User not found"
                                    }
                                </format>
                            </payloadFactory>
                            <property name="HTTP_SC" value="404" scope="axis2"/>
                            <respond/>
                        </then>
                        <else>
                            <enrich>
                                <source property="originalRequest" type="property"/>
                                <target type="body"/>
                            </enrich>
                            <payloadFactory media-type="json">
                                <format>
                                    {
                                    "_putupdateUser":{
                                    "id":$1,
                                    "username":"$2",
                                    "email":"$3",
                                    "first_name":"$4",
                                    "last_name":"$5",
                                    "display_name":"$6",
                                    "profile_image":"$7",
                                    "tenant_id":"$8",
                                    "version":$9,
                                    "updated_by":$10
                                    }
                                    }
                                </format>
                                <args>
                                    <arg expression="get-property('uri.var.id')"/>
                                    <arg evaluator="json" expression="$.username"/>
                                    <arg evaluator="json" expression="$.email"/>
                                    <arg evaluator="json" expression="$.first_name"/>
                                    <arg evaluator="json" expression="$.last_name"/>
                                    <arg evaluator="json" expression="$.display_name"/>
                                    <arg evaluator="json" expression="$.profile_image"/>
                                    <arg evaluator="json" expression="$.tenant_id"/>
                                    <arg evaluator="json" expression="$.version"/>
                                    <arg evaluator="json" expression="$.updated_by"/>
                                </args>
                            </payloadFactory>
                            <!-- <property name="Accept" value="application/json" scope="transport"/> -->
                            <call>
                                <endpoint>
                                    <http method="PUT" uri-template="http://localhost:8290/services/UserDataService_DSS/updateUser"/>
                                </endpoint>
                            </call>
                            <property name="messageType" value="application/json" scope="axis2"/>
                            <property name="ContentType" value="application/json" scope="axis2"/>
                            <respond/>
                        </else>
                    </filter>
                </then>
                <else>
                    <payloadFactory media-type="json">
                        <format>
                            {
                            "success":false,
                            "message":"Invalid User ID"
                            }
                        </format>
                        <args/>
                    </payloadFactory>
                    <property name="HTTP_SC" value="400" scope="axis2"/>
                    <respond/>
                </else>
            </filter>
        </inSequence>
        <faultSequence>
            <log level="full"/>
            <property name="dbError" expression="get-property('ERROR_MESSAGE')"/>
            <filter source="get-property('dbError')" regex=".*users_username_key.*">
                <then>
                    <payloadFactory media-type="json">
                        <format>
                            {
                            "success":false,
                            "message":"Username already exists"
                            }
                        </format>
                    </payloadFactory>
                    <property name="HTTP_SC" value="409" scope="axis2"/>
                    <respond/>
                </then>
                <else>
                    <filter source="get-property('dbError')" regex=".*users_email_key.*">
                        <then>
                            <payloadFactory media-type="json">
                                <format>
                                    {
                                    "success":false,
                                    "message":"Email already exists"
                                    }
                                </format>
                            </payloadFactory>
                            <property name="HTTP_SC" value="409" scope="axis2"/>
                            <respond/>
                        </then>
                        <else>
                            <payloadFactory media-type="json">
                                <format>
                                    {
                                    "success":false,
                                    "message":"Internal Server Error"
                                    }
                                </format>
                            </payloadFactory>
                            <property name="HTTP_SC" value="500" scope="axis2"/>
                            <respond/>
                        </else>
                    </filter>
                </else>
            </filter>
        </faultSequence>
    </resource>
    <!--  ========================== soft delete user ======================= -->
    <resource methods="DELETE" uri-template="/users/{id}">
        <inSequence>
            <log level="custom">
                <property name="id values !!!" expression="$ctx:uri.var.id"/>
            </log>
            <filter source="get-property('uri.var.id')" regex="^[0-9]+$">
                <then>
                    <enrich>
                        <source clone="true" type="body"/>
                        <target property="originalRequest" type="property"/>
                    </enrich>
                    <payloadFactory media-type="xml">
                        <format>
                            <getUserByIdOP>
                                <id>$1</id>
                            </getUserByIdOP>
                        </format>
                        <args>
                            <arg evaluator="xml" expression="get-property('uri.var.id')"/>
                        </args>
                    </payloadFactory>
                    <call>
                        <endpoint key="Get_User_By_Id_Ep"/>
                    </call>
                    <property name="messageType" value="application/json" scope="axis2"/>
                    <property name="ContentType" value="application/json" scope="axis2"/>
                    <property name="userDetails_Result" expression="json-eval($.User.UserDetails)" scope="default"/>
                    <log level="custom">
                        <property name="userDetails_Result" expression="json-eval($.User.UserDetails)" scope="default"/>
                    </log>
                    <filter xpath="get-property('userDetails_Result') = ''">
                        <then>
                            <payloadFactory media-type="json">
                                <format>
                                    {
                                    "success":false,
                                    "message":"User not found"
                                    }
                                </format>
                            </payloadFactory>
                            <property name="HTTP_SC" value="404" scope="axis2"/>
                            <respond/>
                        </then>
                        <else>
                            <enrich>
                                <source property="originalRequest" type="property"/>
                                <target type="body"/>
                            </enrich>
                            <payloadFactory media-type="json">
                                <format>
                                    {
                                    "_deletedeleteUser":{
                                    "id":$1,
                                    "deleted_by":$2
                                    }
                                    }
                                </format>
                                <args>
                                    <arg expression="get-property('uri.var.id')"/>
                                    <arg evaluator="json" expression="$.deleted_by"/>
                                </args>
                            </payloadFactory>
                            <property name="Accept" value="application/json" scope="transport"/>
                            <call>
                                <endpoint>
                                    <http method="DELETE" uri-template="http://localhost:8290/services/UserDataService_DSS/deleteUser"/>
                                </endpoint>
                            </call>
                            <payloadFactory media-type="json">
                                <format>
                                    {
                                    "success":true,
                                    "message":"User deleted successfully"
                                    }
                                </format>
                                <args/>
                            </payloadFactory>
                            <property name="messageType" value="application/json" scope="axis2"/>
                            <property name="ContentType" value="application/json" scope="axis2"/>
                            <property name="HTTP_SC" value="200" scope="axis2"/>
                            <respond/>
                        </else>
                    </filter>
                </then>
                <else>
                    <payloadFactory media-type="json">
                        <format>
                            {
                            "success":false,
                            "message":"Invalid User ID"
                            }
                        </format>
                    </payloadFactory>
                    <property name="HTTP_SC" value="400" scope="axis2"/>
                    <respond/>
                </else>
            </filter>
        </inSequence>
        <faultSequence>
            <log level="full"/>
            <respond/>
        </faultSequence>
    </resource>
    <!-- ============================  put user activate ===================== -->
    <resource methods="PUT" uri-template="/users/{id}/activate">
        <inSequence>
            <filter source="get-property('uri.var.id')" regex="^[0-9]+$">
                <then>
                    <enrich>
                        <source clone="true" type="body"/>
                        <target property="originalRequest" type="property"/>
                    </enrich>
