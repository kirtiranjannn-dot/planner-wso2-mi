    <!-- =================  Put Plan API  ================= -->
    <resource methods="PUT" uri-template="/plans/{id}">
        <inSequence>
            <payloadFactory media-type="json">
                <format>
                    {
                    "_putupdatePlan": {
                    "id": $1,
                    "name": "$2",
                    "description":"$3",
                    "owner_id": $4,
                    "color": "$5",
                    "icon": "$6",
                    "visibility": "$7",
                    "status":"$8",
                    "start_date": "$9",
                    "end_date": "$10",
                    "tenant_id":"$11",
                    "version": $12,
                    "updated_by": $13
                    }
                    }
                </format>
                <args>
                    <arg expression="get-property('uri.var.id')"/>
                    <arg evaluator="json" expression="$.name"/>
                    <arg evaluator="json" expression="$.description"/>
                    <arg evaluator="json" expression="$.owner_id"/>
                    <arg evaluator="json" expression="$.color"/>
                    <arg evaluator="json" expression="$.icon"/>
                    <arg evaluator="json" expression="$.visibility"/>
                    <arg evaluator="json" expression="$.status"/>
                    <arg evaluator="json" expression="$.start_date"/>
                    <arg evaluator="json" expression="$.end_date"/>
                    <arg evaluator="json" expression="$.tenant_id"/>
                    <arg evaluator="json" expression="$.version"/>
                    <arg evaluator="json" expression="$.updated_by"/>
                </args>
            </payloadFactory>
            <property name="Accept" value="application/json" scope="transport"/>
            <call>
                <endpoint>
                    <http method="PUT" uri-template="http://localhost:8290/services/PlanDataService_DSS/updatePlan"/>
                </endpoint>
            </call>
            <property name="messageType" value="application/json" scope="axis2"/>
            <property name="ContentType" value="application/json" scope="axis2"/>
            <respond/>
        </inSequence>
        <faultSequence>
            <log level="full"/>
            <respond/>
        </faultSequence>
    </resource>
